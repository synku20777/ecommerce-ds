---
import '../styles/global.scss';

export interface Props {
  title?: string;
}

const { title = 'E-Commerce Design System' } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="React + TypeScript component library documentation powered by Astro." />
    <title>{title}</title>
  </head>
  <body>
    <slot />

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const storageKey = 'ds-theme';

        const applyTheme = (theme) => {
          root.setAttribute('data-theme', theme);
          document.body.setAttribute('data-theme', theme);

          document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
            button.textContent = theme === 'dark' ? 'Switch to Light' : 'Switch to Dark';
            button.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
          });
        };

        const saved = localStorage.getItem(storageKey);
        const initial = saved === 'dark' || saved === 'light' ? saved : 'light';
        applyTheme(initial);

        document.addEventListener('click', (event) => {
          const trigger = event.target instanceof Element ? event.target.closest('[data-theme-toggle]') : null;
          if (!trigger) {
            return;
          }

          const current = root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
          const next = current === 'dark' ? 'light' : 'dark';
          localStorage.setItem(storageKey, next);
          applyTheme(next);
        });
      })();
    </script>
  </body>
</html>
